# Anthropic / Claude
ANTHROPIC_API_KEY=

# Pionex API credentials (used by the Pionex MCP server, NOT read directly by this script)
PIONEX_API_KEY=
PIONEX_API_SECRET=

# Command used to launch the Pionex MCP server (stdio). Adjust to whatever
# package/binary you use to run it, e.g.:
#   npx -y pionex-mcp
#   python -m pionex_mcp_server
PIONEX_MCP_COMMAND=npx
PIONEX_MCP_ARGS=-y,pionex-mcp
